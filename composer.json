{
    "name": "lwekuiper/statamic-acumbamail",
    "license": "proprietary",
    "type": "statamic-addon",
    "require": {
        "statamic/cms": "^4.0 || ^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^12.0"
    },
    "description": "Subscribe registrations or contact forms to Acumbamail",
    "authors": [
        {
            "name": "Laurens Kuiper",
            "email": "l@urens.me"
        }
    ],
    "autoload": {
        "psr-4": {
            "Lwekuiper\\StatamicAcumbamail\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lwekuiper\\StatamicAcumbamail\\Tests\\": "tests"
        }
    },
    "extra": {
        "statamic": {
            "name": "Statamic Acumbamail",
            "description": "Acumbamail integration for Statamic",
            "editions": ["free", "lite", "pro"]
        },
        "laravel": {
            "providers": [
                "Lwekuiper\\StatamicAcumbamail\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    }
}
